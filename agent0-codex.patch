+                <span x-text="$store.codexProvider.proxyRunning ? 'Running' : 'Stopped'"></span>
+                <template x-if="$store.codexProvider.proxyUrl">
+                  <span>• <code x-text="$store.codexProvider.proxyUrl"></code></span>
