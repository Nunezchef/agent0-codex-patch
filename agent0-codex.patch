+      }
+
+      .codex-toggle-label {
+        margin-left: 0.75rem;
+      }
+
+      .codex-bottom-actions {
+        margin-top: 1rem;
+      }
+
+      .codex-error {
+        margin-top: 1rem;
+        color: #f87171;
